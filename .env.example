# Prefer providing tokens via process environment (not committed to disk).
# If you do want to use .env locally, set them here:
GITHUB_TOKEN=
# or:
GH_TOKEN=
GITHUB_REPOS=owner/repo

# Required only for `serve` (webhook) mode — the shared secret configured on the
# GitHub webhook. Used to verify the X-Hub-Signature-256 of incoming payloads.
GITHUB_WEBHOOK_SECRET=

JOB_RUNNER=local-docker

WORKER_MENTION=@worker
LABEL_ACCEPTED=accepted
LABEL_IN_PROGRESS=in-progress
LABEL_DONE=done

POLL_INTERVAL_SECONDS=900
MAX_ACCEPT_PER_RUN=1
MAX_CONCURRENT_WORKERS=5
DRY_RUN=true

AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_LOCATION=westeurope

# Prefer Managed Identity in Azure:
AZURE_USE_MANAGED_IDENTITY=true

# If running locally with a service principal instead:
# AZURE_USE_MANAGED_IDENTITY=false
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

ACA_ENV_NAME=
ACA_JOB_NAME=autofactory-issue-agent
# Required only when DRY_RUN=false:
WORKER_IMAGE=

# LLM provider — set exactly one of the following key strategies.
# The LLM_MODEL prefix selects the provider (openai/, anthropic/, azure/).
# Option A — OpenAI API:
OPENAI_API_KEY=
# Option B — Anthropic API (use with LLM_MODEL=anthropic/claude-...):
# ANTHROPIC_API_KEY=
# Option C — Azure OpenAI (use with LLM_MODEL=azure/<deployment-name>;
#   deployment name must match the model name). AZURE_RESOURCE_NAME is the
#   *.openai.azure.com subdomain, not the full URL:
# AZURE_API_KEY=
# AZURE_RESOURCE_NAME=my-resource
# Option D — Claude subscription (monthly Pro/Max plan, no per-token API key).
#   Run `scripts/opencode-auth.sh login` once, then `export-local` to populate
#   this with the single-line contents of OpenCode's auth.json. Use with
#   LLM_MODEL=anthropic/claude-...:
# OPENCODE_AUTH_JSON=

LLM_MODEL=openai/gpt-5-mini
